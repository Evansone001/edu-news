# ============================================
# Sheria News Blog - Environment Configuration
# ============================================

# Ghost CMS API Configuration
# Get these from your Ghost admin panel (Settings > Integrations)
NEXT_PUBLIC_GHOST_API_URL=https://your-ghost-instance.ghost.io
NEXT_PUBLIC_GHOST_CONTENT_API_KEY=your_ghost_content_api_key_here

# Optional: Upstash Redis (for caching)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Node Environment (set automatically by hosting platform)
NODE_ENV=production
